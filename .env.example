# Copy this file to .env and fill in your own values.
#   cp .env.example .env

# ── App ─────────────────────────────────────────────────────────────────────
DEBUG=false
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-to-a-random-secret

# ── Database (asyncpg URL — matches docker-compose's postgres service) ──────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/tunescope
# Optional: sync URL for Alembic migrations. Auto-derived from DATABASE_URL
# (asyncpg -> psycopg2) if left blank.
DATABASE_URL_SYNC=

# ── Redis ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Spotify OAuth ─────────────────────────────────────────────────────────
# Create an app at https://developer.spotify.com/dashboard and add
# SPOTIFY_REDIRECT_URI below as a Redirect URI on that app.
SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret
SPOTIFY_REDIRECT_URI=http://localhost:8000/auth/callback
